# Backoffice API (apps/backoffice) — domain routes for assets, intervals,
# tasks, created markets, and the manual creator's /manual/* endpoints.
# Used by lib/api.ts.
BACKOFFICE_API_URL=http://localhost:8092
BACKOFFICE_API_KEY=backoffice-api-key

# dpm-api (apps/dpm-api) — used by the Admin section (HD mnemonic +
# relayer-wallet init/list/withdraw) and the market UMA/lifecycle actions.
# DPM_API_KEY is the admin secret (privileged writes); DPM_APP_API_KEY is the
# app secret for protected reads (wallet list, mnemonic status, balances).
DPM_API_URL=http://localhost:8082
DPM_API_KEY=dpm-api-key
DPM_APP_API_KEY=dpm-app-api-key

# Known infrastructure contract addresses for the /admin/contracts page.
# All-or-nothing: set every one for production, or leave all unset to use the
# built-in Polygon Amoy *testnet* addresses (the page shows a "Testnet defaults"
# warning). A partial set is treated as a misconfiguration and errors in the UI.
# Inlined client-side (NEXT_PUBLIC_) at build time.
NEXT_PUBLIC_CONTRACT_USDC_E=
NEXT_PUBLIC_CONTRACT_CONDITIONAL_TOKENS=
NEXT_PUBLIC_CONTRACT_CTF_EXCHANGE=
NEXT_PUBLIC_CONTRACT_FEE_MODULE=
NEXT_PUBLIC_CONTRACT_UMA_CTF_ADAPTER=
NEXT_PUBLIC_CONTRACT_MANAGED_ORACLE=
NEXT_PUBLIC_CONTRACT_CTF_ORACLE=
NEXT_PUBLIC_CONTRACT_TREASURY=

# Google Generative AI (Gemini) — used by /api/manual/ai-draft to draft
# event/series payloads from a freeform description and to adapt Polymarket
# slug payloads. Either GOOGLE_GENERATIVE_AI_API_KEY or GEMINI_API_KEY works;
# the route prefers the former and falls back to the latter.
GOOGLE_GENERATIVE_AI_API_KEY=

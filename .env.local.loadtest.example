# prediction-backoffice — LOAD TEST environment template.
#
# This config points every backend dependency at LOCAL load-test mock servers
# instead of the real services, so the backoffice can be driven at high request
# volume without touching production or real upstreams.
#
# Setup:
#   cp .env.local.loadtest.example .env.local.loadtest
#   # fill in any placeholder secrets below
#
# Run:
#   npm run dev:loadtest                      # quick check (dev server)
#   npm run build && npm run start:loadtest   # realistic, production-like load test
#
# The npm scripts inject this file into process.env via `node --env-file=...`.
# Next.js checks process.env BEFORE .env.local, so these values win during a
# load test while your normal .env.local stays untouched.

# dpm-api — load-test mock on :9086 (real dev default is :8086).
# DPM_API_KEY is the admin secret (privileged writes); DPM_APP_API_KEY is the
# app secret for protected reads. Must match the load-test harness.
DPM_API_URL=http://localhost:9086
DPM_API_KEY=loadtest-dpm-admin
DPM_APP_API_KEY=loadtest-app

# Backoffice API (apps/backoffice) — load-test mock on :9092 (real dev default
# is :8092). Used by lib/api.ts for assets, intervals, tasks, created markets.
BACKOFFICE_API_URL=http://localhost:9092
BACKOFFICE_API_KEY=backoffice-api-key

# api-football — points at the local load-test mock on :9101 instead of the
# real api-sports key, so fixture/odds calls never leave the machine.
APIFOOTBALL_API_KEY=http://127.0.0.1:9101

# Google Gemini (AI form-fill, /api/manual/ai-draft). Leave blank to keep AI
# calls disabled during the load test, or supply a key if you are specifically
# load-testing the AI path. Either name works.
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_API_KEY=

# Per-user daily AI cost cap, in USD.
AI_DAILY_COST_CAP_USD=5
